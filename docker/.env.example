# Copie para .env e ajuste os valores. O arquivo .env NÃO é versionado.
#
# REGRAS PARA SENHAS:
# - Mínimo 12 caracteres (EspoCRM exige ≥ 8; use 12+ por segurança).
# - Apenas letras e números. EVITE $ " ' ` \ { } — quebram parsing do Docker Compose
#   (em especial, $ é interpretado como variável).
# - Gerar em PowerShell:
#     1..6 | ForEach-Object { -join ((48..57 + 65..90 + 97..122) | Get-Random -Count 20 |
#       ForEach-Object {[char]$_}) }

# ------------------------------------------------------------------------------
# Versões de imagens (pin obrigatório)
# ------------------------------------------------------------------------------
# Alterar versão em um único lugar; docker-compose.yml consome via ${VARIABLE}.
# MariaDB precisa ser ≥10.6 (exigência do ADR 0005 — SELECT FOR UPDATE SKIP LOCKED).
# Caddy ≥2.8 tem suporte estável a TLS 1.3 exclusivo (ADR 0004).
MARIADB_VERSION=11.4
ESPOCRM_VERSION=9.3
NEXTCLOUD_VERSION=31-apache
POSTGRES_VERSION=16
REDIS_VERSION=7-alpine
CADDY_VERSION=2.8

# ------------------------------------------------------------------------------
# Caddy / domínio público
# ------------------------------------------------------------------------------
# Em dev local, manter "localhost" — Caddy usará sua CA interna (cert auto-assinado).
# Em produção, trocar para o domínio real (ex.: crm.escritorio.adv.br) e o Caddy
# provisiona Let's Encrypt automaticamente usando CADDY_TLS_EMAIL.
TOGARE_DOMAIN=localhost
CADDY_TLS_EMAIL=admin@exemplo.com

# ------------------------------------------------------------------------------
# MariaDB (EspoCRM)
# ------------------------------------------------------------------------------
MARIADB_ROOT_PASSWORD=21JcU9r8Lh8C
ESPOCRM_DB_NAME=espocrm
ESPOCRM_DB_USER=espocrm
ESPOCRM_DB_PASSWORD=21JcU9r8Lh8C

# EspoCRM admin
ESPOCRM_ADMIN_USERNAME=admin
ESPOCRM_ADMIN_PASSWORD=21JcU9r8Lh8C

# Postgres (Nextcloud)
NEXTCLOUD_DB_NAME=nextcloud
NEXTCLOUD_DB_USER=nextcloud
NEXTCLOUD_DB_PASSWORD=21JcU9r8Lh8C

# Nextcloud admin
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=21JcU9r8Lh8C

# Redis
# Servidor compartilhado entre Nextcloud (DB 0) e togare-tpu (DB 1, Story 3.3 —
# isolamento via TOGARE_REDIS_DB no docker-compose.yml). Senha única para
# ambos consumidores.
REDIS_PASSWORD=21JcU9r8Lh8C

# ------------------------------------------------------------------------------
# DJEN — togare-djen (Story 4a.1)
# ------------------------------------------------------------------------------
# Base URL da Comunica API PJe (consulta pública DJEN, sem auth). Endpoint
# canônico: comunicaapi.pje.jus.br/api/v1. Override útil para apontar fixture
# local em CI/dev (ex.: file:///app/fixtures/comunica-api.json).
TOGARE_DJEN_BASE_URL=https://comunicaapi.pje.jus.br/api/v1

# Story 4b.4 / ADR 0009 — path do state-file do circuit breaker do
# DjenAdapter. **Hardcoded em docker-compose.yml** para `/var/togare-djen/
# circuit-breaker.json` (volume Docker compartilhado entre `espocrm` e
# `togare-djen-worker`). Override via env var é suportado mas não-canônico
# em deploy Docker — os 2 containers DEVEM apontar para o mesmo path em
# volume compartilhado, senão o snapshot endpoint retorna `cbOpen=false`
# enquanto o worker enxerga CB aberto. Em deploy não-Docker (futuro
# enterprise self-host), apontar para path em filesystem compartilhado
# (NFS/CIFS) — `flock()` precisa funcionar.
# Default no DjenAdapter (sem env var): sys_get_temp_dir() + nome do file.
# TOGARE_DJEN_CB_STATE_PATH=/var/togare-djen/circuit-breaker.json

# ------------------------------------------------------------------------------
# Nextcloud bridge — togare-nextcloud-bridge (Story 5.1)
# ------------------------------------------------------------------------------
# Base URL do Nextcloud para WebDAV/OCS. Default `http://nextcloud:80` (DNS
# interno Docker — bridge consome direto, sem passar pelo Caddy externo).
# Override útil para fixture local em CI: `file:///app/fixtures/`.
TOGARE_NEXTCLOUD_BASE_URL=http://nextcloud:80

# User Nextcloud que a bridge usa pra WebDAV/OCS. Vazio = bridge cai no
# NEXTCLOUD_ADMIN_USER deste mesmo arquivo (MVP single-tenant).
# Em produção, criar user dedicado `togare-bridge` via Admin Nextcloud +
# setar TOGARE_NEXTCLOUD_USER aqui (Decisão #6 da Story 5.1, deferida pra
# Growth com Group Folders).
TOGARE_NEXTCLOUD_USER=
TOGARE_NEXTCLOUD_PASSWORD=

# Tamanho máximo (em MB) de cada Documento upload (Story 5.2 Decisão #6).
# Validado server-side em ValidateDocumentoFieldsHook. Frontend exibe Toast
# pt-BR quando excedido. PHP_overrides cobrem upload_max_filesize / post_max_size
# proporcionais (210M / 220M).
TOGARE_MAX_DOCUMENT_SIZE_MB=200

# ------------------------------------------------------------------------------
# LocalDisk storage fallback — Story 6.0
# ------------------------------------------------------------------------------
# Root absoluto (DENTRO do container espocrm) onde o LocalDiskStorage do
# togare-core grava binários quando o togare-nextcloud-bridge NÃO está
# instalado (ou quando o admin opta explicitamente por LocalDisk). Quando o
# bridge está instalado/autoloadable, o Binding da togare-core pula o fallback
# e deixa o Binding da bridge resolver FileStorageContract para Nextcloud.
#
# Volume Docker nomeado `togare_local_storage` mapeia este path nos containers
# espocrm e espocrm-daemon; o container togare-backup snapshota o mesmo volume
# via restic (mount read-only).
#
# Default: /var/togare/local-storage. Override apenas se houver razão
# operacional (ex.: redirecionar para sub-path de volume Docker já existente).
TOGARE_LOCAL_STORAGE_ROOT=/var/togare/local-storage

# ------------------------------------------------------------------------------
# Download proxy — Story 5.3
# ------------------------------------------------------------------------------
# Branch dual para download de Documento. Default `false` = X-Accel-Redirect
# (Caddy serve direto do volume nextcloud_data via /internal-nextcloud, sem
# PHP-FPM tocar bytes — NFR1 p95 ≤ 2s preservado). `true` = PHP-proxy chunked
# via cURL CURLOPT_FILE = php://output (1MB buffer, não carrega body em
# memória). Promover apenas se bench VPS Fase 2 da Spike 1b.S1 (Epic 10)
# revelar p95 TTFB > 2.5s sustentado no X-Accel. Ver ADR 0004b draft.
TOGARE_DOWNLOAD_USE_PHP_PROXY=false

# ------------------------------------------------------------------------------
# Backup (container togare-backup — Story 1a.7)
# ------------------------------------------------------------------------------
# Imagem restic pinada. Atualizar sempre via PR explícito; upgrade de major
# pode exigir `restic migrate`. Última estável (2026-04): 0.17.3.
RESTIC_VERSION=0.17.3

# Cron diário do backup (TZ=America/Sao_Paulo no compose; sem isso roda em UTC).
# Default 02:00 Brasília. Aspas obrigatórias por causa dos espaços.
BACKUP_CRON_EXPRESSION="0 2 * * *"

# Cron semanal de manutenção (restic prune + check 5%). Default domingo 03:00.
# Separado do diário porque prune é caro (repack) e degrada a janela de 26h.
PRUNE_CRON_EXPRESSION="0 3 * * 0"

# Quantos snapshots diários manter (passado para `restic forget --keep-daily=N`).
BACKUP_RETENTION_DAYS=30

# Senha de cifragem do repositório restic. OBRIGATÓRIA. Sem ela:
#   - backup falha imediatamente no entrypoint;
#   - sem ela é IMPOSSÍVEL restaurar (chave de descriptografia do repo).
# REGRAS (mesmas do cabeçalho deste arquivo, REFORÇADAS aqui):
#   - 20+ caracteres ALFANUMÉRICOS apenas;
#   - SEM $ " ' \ ` { } — Compose corrompe parsing silenciosamente, backups
#     viram irrecuperáveis. O entrypoint do container rejeita esses chars.
# Guardar cópia FORA do servidor (gerenciador de senhas do Sócio).
RESTIC_PASSWORD=

# Path no host para o repositório restic (bind mount). Relativo a docker/.
# Diretório é gitignored. Em Linux produção, owner pode ficar root:root —
# ver "Aviso de ownership" no README.
TOGARE_BACKUP_LOCAL_PATH=./backup-data
