# Caddyfile do Togare — reverse proxy único da stack (ADR 0004).
#
# Responsabilidades:
#   - TLS 1.3 exclusivo em todas as conexões externas (NFR7 — Story 1a.1).
#   - HSTS condicional em produção (max-age=1 ano + includeSubDomains — Story 2.5).
#     Excluído em localhost para não travar navegador em troubleshooting dev.
#   - Redirect HTTP → HTTPS automático (Caddy gera virtual host na porta 80).
#   - Roteamento para EspoCRM (raiz) e Nextcloud (files.<dominio>).
#   - Injeção de correlation id (X-Togare-Correlation-Id) se ausente (Story 1a.4a).
#
# Pendências de stories futuras (NÃO tratar aqui):
#   - Rate limit por IP via plugin caddy-ratelimit — deferido para Growth (ADR 0004).
#   - Subdomínio portal.<dominio> dedicado ao Portal do Cliente — ADR 0007 / Story 7a.x.
{
	# Bloco global.
	# Email usado pelo Let's Encrypt em domínios externos. Ignorado em localhost (tls internal).
	email {$CADDY_TLS_EMAIL}

	# Habilita HTTP/1.1, HTTP/2 e HTTP/3. HTTP/3 exige porta 443/udp publicada (já no compose).
	servers {
		protocols h1 h2 h3
	}
}

# -----------------------------------------------------------------------------
# Site principal — EspoCRM (CRM do escritório).
# Em localhost: Caddy usa CA interna (cert auto-assinado → avisos no navegador).
# Em produção: Caddy provisiona Let's Encrypt automaticamente a partir do domínio.
# -----------------------------------------------------------------------------
{$TOGARE_DOMAIN} {
	tls {
		protocols tls1.3
	}

	# HSTS: somente em produção. Localhost com cert auto-assinado + HSTS persistente
	# trava o navegador em troubleshooting — foot-gun. Em produção é obrigatório (NFR7).
	@notLocalhost not host localhost
	header @notLocalhost Strict-Transport-Security "max-age=31536000; includeSubDomains"

	# Correlation id: se o cliente não enviou, geramos um UUID por requisição.
	# Middleware EspoCRM da Story 1a.4a consome este header para logs estruturados
	# (ADR 0007). Caddy preserva valor de entrada quando presente.
	@no_correlation_id not header X-Togare-Correlation-Id *
	request_header @no_correlation_id X-Togare-Correlation-Id {http.request.uuid}

	# Espelha o header na resposta para facilitar correlação client-side.
	header >X-Togare-Correlation-Id {http.request.header.X-Togare-Correlation-Id}

	reverse_proxy espocrm:80 {
		header_up X-Forwarded-Proto https

		# Story 5.3: X-Accel-Redirect — Caddy serve binário do volume
		# nextcloud_data:/internal-nextcloud:ro quando o upstream EspoCRM
		# devolve o header `X-Accel-Redirect: /internal-nextcloud/...`.
		# Matcher restritivo previne paths arbitrários injetados via header
		# forjado (defesa em profundidade — só dispara para o prefixo interno).
		# Receita validada na Spike 1b.S1 Fase 1 (Alternativa A: file_server
		# dentro do handle_response com root * /).
		@hasAccelRedirect header X-Accel-Redirect /internal-nextcloud/*
		handle_response @hasAccelRedirect {
			route {
				root * /internal-nextcloud
				rewrite * {rp.header.X-Accel-Redirect}
				uri strip_prefix /internal-nextcloud
				file_server
			}
		}
	}
}

# -----------------------------------------------------------------------------
# Subdomínio files — Nextcloud (hospedagem de arquivos).
# -----------------------------------------------------------------------------
files.{$TOGARE_DOMAIN} {
	tls {
		protocols tls1.3
	}

	# HSTS no subdomínio files — incluso explicitamente mesmo que o includeSubDomains
	# da raiz cubra tecnicamente, para legibilidade de audit.
	@notLocalhost not host localhost
	header @notLocalhost Strict-Transport-Security "max-age=31536000; includeSubDomains"

	@no_correlation_id not header X-Togare-Correlation-Id *
	request_header @no_correlation_id X-Togare-Correlation-Id {http.request.uuid}
	header >X-Togare-Correlation-Id {http.request.header.X-Togare-Correlation-Id}

	reverse_proxy nextcloud:80 {
		header_up X-Forwarded-Proto https
	}
}
