# Configuração avançada (OPCIONAL) do restic.
# Este arquivo é ILUSTRATIVO — NÃO é consumido pelo docker-compose por default.
# Serve como referência para quem quiser ativar destino S3-compatible no futuro
# (MinIO, Backblaze B2, AWS S3, Wasabi).
#
# Para ATIVAR destino S3-compat:
#   1. Copiar as variáveis abaixo para docker/.env.
#   2. Adicionar `RESTIC_REPOSITORY_S3` ao bloco `environment:` do serviço
#      togare-backup no docker-compose.yml e ajustar o entrypoint para
#      preferir RESTIC_REPOSITORY_S3 sobre o local quando definida.
#   3. Validar com `docker compose run --rm togare-backup restic snapshots`.
#
# MVP padrão é SOMENTE LOCAL. Spike para depois.

# Chave de cifragem (OBRIGATÓRIA — mesma do .env do compose)
RESTIC_PASSWORD=

# Destino LOCAL (default; usado se RESTIC_REPOSITORY_S3 estiver vazia)
RESTIC_REPOSITORY=/var/backups/togare

# Destino S3-COMPAT (opcional — descomentar para ativar)
# Sintaxe: s3:<endpoint>/<bucket>[/<prefix>]
# Exemplos:
#   s3:s3.amazonaws.com/togare-backup-prod
#   s3:s3.us-west-002.backblazeb2.com/togare-mvp
#   s3:minio.escritorio.local:9000/togare
# RESTIC_REPOSITORY_S3=s3:s3.amazonaws.com/togare-backup

# Credenciais S3 (obrigatórias se RESTIC_REPOSITORY_S3 ativa)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# Chave de servidor REST (alternativa a S3 — restic oficial expõe servidor próprio)
# RESTIC_REPOSITORY=rest:https://backup.escritorio.local:8000/
# RESTIC_REST_USERNAME=
# RESTIC_REST_PASSWORD=
