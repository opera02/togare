{
    "fields": {
        "name": {
            "type": "varchar",
            "notStorable": true,
            "readOnly": true,
            "select": {"select": "descricao"},
            "order": {"order": [["dataMovimento", "{direction}"]]}
        },
        "descricao": {
            "type": "varchar",
            "maxLength": 200,
            "trim": true,
            "required": true,
            "audited": true
        },
        "tipo": {
            "type": "enum",
            "options": [
                "pagamento_total",
                "pagamento_parcial",
                "despesa_interna",
                "receita_avulsa",
                "acerto",
                "estorno"
            ],
            "required": true,
            "audited": true
        },
        "valor": {
            "type": "currency",
            "min": 0.01,
            "required": true,
            "defaultCurrency": "BRL",
            "audited": true
        },
        "dataMovimento": {
            "type": "date",
            "required": true,
            "audited": true
        },
        "formaPagamento": {
            "type": "enum",
            "options": [
                "",
                "dinheiro",
                "pix",
                "boleto",
                "transferencia_bancaria",
                "cartao_credito",
                "cartao_debito",
                "cheque",
                "outro"
            ],
            "default": null,
            "audited": true
        },
        "categoria": {
            "type": "varchar",
            "maxLength": 50,
            "trim": true,
            "default": null
        },
        "observacoes": {
            "type": "text",
            "trim": true,
            "default": null
        },
        "fatura": {
            "type": "link",
            "required": false,
            "view": "togare-core:views/fields/link-autocomplete"
        },
        "faturaName": {
            "type": "varchar",
            "notStorable": true,
            "readOnly": true,
            "select": {"select": "fatura.numero"},
            "order": {"order": [["fatura.numero", "{direction}"]]}
        },
        "cliente": {
            "type": "link",
            "required": true,
            "view": "togare-core:views/fields/link-autocomplete"
        },
        "clienteName": {
            "type": "varchar",
            "notStorable": true,
            "readOnly": true,
            "select": {"select": "cliente.name"},
            "order": {"order": [["cliente.name", "{direction}"]]}
        },
        "processo": {
            "type": "link",
            "required": false,
            "view": "togare-core:views/common/fields/processo-by-cliente"
        },
        "processoName": {
            "type": "varchar",
            "notStorable": true,
            "readOnly": true,
            "select": {"select": "processo.numeroCnj"},
            "order": {"order": [["processo.numeroCnj", "{direction}"]]}
        },
        "assignedUser": {
            "type": "link",
            "required": false
        },
        "tenantId": {
            "type": "varchar",
            "maxLength": 40,
            "readOnly": true,
            "tooltip": false
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "fatura": {
            "type": "belongsTo",
            "entity": "Fatura",
            "foreign": "lancamentosFinanceiros"
        },
        "cliente": {
            "type": "belongsTo",
            "entity": "Cliente",
            "foreign": "lancamentosFinanceiros"
        },
        "processo": {
            "type": "belongsTo",
            "entity": "Processo",
            "foreign": "lancamentosFinanceiros"
        }
    },
    "indexes": {
        "faturaId": {
            "columns": ["faturaId"]
        },
        "clienteId": {
            "columns": ["clienteId"]
        },
        "processoId": {
            "columns": ["processoId"]
        },
        "tipo": {
            "columns": ["tipo"]
        },
        "dataMovimento": {
            "columns": ["dataMovimento"]
        },
        "tenantId": {
            "columns": ["tenantId"]
        }
    },
    "collection": {
        "orderBy": "dataMovimento",
        "order": "desc",
        "textFilterFields": ["descricao", "categoria", "cliente.name"]
    }
}
