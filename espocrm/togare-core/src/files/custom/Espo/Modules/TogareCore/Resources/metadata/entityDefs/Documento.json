            "readOnly": true,
            "select": {"select": "filename"},
            "order": {"order": [["filename", "{direction}"]]},
            "where": {
                "LIKE": {"whereClause": {"filename*": "{value}"}}
            }
        },
        "filename": {
            "type": "varchar",
            "maxLength": 100,
            "trim": true,
            "readOnly": true
