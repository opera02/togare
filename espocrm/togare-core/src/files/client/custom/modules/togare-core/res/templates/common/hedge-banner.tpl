<aside class="{{cssClass}}" data-variant="{{variant}}">
    <span class="togare-hedge-banner__icon" aria-hidden="true">ⓘ</span>
    <span class="togare-hedge-banner__text">{{text}}</span>
    {{#if learnMoreLabel}}
        {{#if learnMoreUrl}}
            <a class="togare-hedge-banner__link" href="{{learnMoreUrl}}" target="_blank" rel="noopener">{{learnMoreLabel}}</a>
        {{/if}}
    {{/if}}
</aside>
