{
    "compilerOptions": {
        "paths": {
            "*": ["./site/client/src/*"],
            "modules/crm/*": ["./site/client/modules/crm/src/*"],
            "modules/togare-portal-ui/*": ["./src/files/client/custom/modules/togare-portal-ui/src/*"]
        },
        "module": "ES6",
        "target": "ES2018",
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "allowJs": true,
        "checkJs": false,
        "noEmit": true
    }
}
